# ==============================================================================
# UrbanBrain - Variables de Entorno (Plantilla)
# ==============================================================================

# ------------------------------------------------------------------------------
# Base de Datos (Drizzle / Postgres)
# ------------------------------------------------------------------------------
# URL de conexión directa a PostgreSQL. Usada por Drizzle ORM para queries
# y migraciones. En Supabase, usa el pooler en el puerto 6543 (Transaction mode).
DATABASE_URL="postgresql://postgres.xxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# ------------------------------------------------------------------------------
# Supabase (Auth y API pública)
# ------------------------------------------------------------------------------
# Variables públicas inyectadas en el cliente Next.js para Supabase Auth.
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR..."

# ------------------------------------------------------------------------------
# Motor UrbanBrain IA (Futuro)
# ------------------------------------------------------------------------------
# API Key del servicio Python interno (Agente Normativas)
# URBANBRAIN_ENGINE_API_KEY="sk-..."
# URBANBRAIN_ENGINE_URL="http://localhost:8000"

# ------------------------------------------------------------------------------
# Feature Flags y Configuración V2 (Sprint 3.12)
# ------------------------------------------------------------------------------
# KNOWLEDGE_ENGINE: Motor activo (v1 o v2). 'v2' usa embeddings en pgvector.
KNOWLEDGE_ENGINE=v2
# ENABLE_CTE_V2_RESPONSES: Si es 'true', permite usar respuestas CTE del corpus V2 en laboratorio.
ENABLE_CTE_V2_RESPONSES=false
# CTE_V2_MIN_SIMILARITY: Umbral estricto para aceptar fragmentos V2.
CTE_V2_MIN_SIMILARITY=0.65
